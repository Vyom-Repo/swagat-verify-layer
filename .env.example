# ============================================================
# Lakshya Grievance Redressal System — Environment Variables
# ============================================================
# Copy this file to .env and update values for your environment.
#
#   cp .env.example .env
#
# ============================================================

# --- Database ---
DATABASE_URL=postgresql://postgres:password@localhost:5432/lakshya_db

# --- Twilio IVR (leave blank for simulation mode) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# --- Verification ---
GPS_DISTANCE_THRESHOLD_METERS=500

# --- App ---
BASE_URL=http://localhost:8000
